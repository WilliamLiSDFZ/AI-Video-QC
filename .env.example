# 复制为 .env 并填入实际值（.env 已被 .gitignore 排除，不会提交）
# 环境变量中已有的同名变量优先于 .env 中的值

# Claude API key（必填，二选一：API key 或 AUTH_TOKEN）
ANTHROPIC_API_KEY=

# 使用代理/中转服务时设置
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_AUTH_TOKEN=

# VBench 环境的 Python 解释器路径（也可写在 config yaml 的 prescreen.vbench_python）
# VBENCH_PYTHON=/opt/miniconda3/envs/vbench/bin/python
